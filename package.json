{
  "name": "edusphere",
  "version": "1.0.0",
  "private": true,
  "description": "EduSphere - A Scalable Video-Based E-Learning and Skill Marketplace Platform",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:shared && concurrently \"npm run dev:shared\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:shared": "npm run dev --workspace=@edusphere/shared",
    "dev:server": "npm run dev --workspace=@edusphere/server",
    "dev:client": "npm run dev --workspace=@edusphere/client",
    "build": "npm run build --workspaces",
    "build:shared": "npm run build --workspace=@edusphere/shared",
    "build:server": "npm run build --workspace=@edusphere/server",
    "build:client": "npm run build --workspace=@edusphere/client",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "EduSphere Team",
  "license": "MIT"
}
